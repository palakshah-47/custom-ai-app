# Chat uses Ollama by default (see src/hooks/useChat.js). No API key needed.

# URL your dev server proxies to (Docker on host: usually http://127.0.0.1:11434).
# If Vite runs inside Docker, use the Ollama service name, e.g. http://ollama:11434
OLLAMA_HOST=http://127.0.0.1:11434

# Model name as shown by `ollama list` (e.g. tinyllama, llama3.2, phi3)
VITE_OLLAMA_MODEL=tinyllama

# Optional: Anthropic proxy is still available at /api/anthropic if you add a key.
# Get a key from https://console.anthropic.com/ — never commit the real .env file.
ANTHROPIC_API_KEY=
